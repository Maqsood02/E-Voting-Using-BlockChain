# Port on which Express server listens
PORT=5000

# RPC URL of your Ethereum provider (e.g., local Hardhat, Ganache, or Sepolia via Infura/Alchemy)
RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_API_KEY

# Ethereum wallet private key of the admin/owner (keep this extremely secure)
PRIVATE_KEY=your_admin_wallet_private_key_here

# Deployed Smart Contract address
CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000
