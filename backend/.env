# ── Votify Backend Configuration ─────────────────────────────────────────────
# Port the Express server listens on
PORT=5000

# ── Blockchain Settings (leave blank to run in simulation/localStorage mode) ──
# To connect to a real blockchain, fill these in:

# Option A: Local Hardhat/Ganache (for testing)
# RPC_URL=http://127.0.0.1:8545

# Option B: Ethereum Testnet via Alchemy (Sepolia)
# RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_API_KEY

RPC_URL=http://127.0.0.1:8545

# Admin wallet private key (from MetaMask or Hardhat test account)
# NEVER commit a real private key to git!
PRIVATE_KEY=

# Deployed smart contract address (from Remix or Hardhat deploy)
CONTRACT_ADDRESS=

# ── MongoDB Settings ───────────────────────────────────────────────────────
# Replace <db_password> with your actual MongoDB Atlas password
MONGODB_URI=mongodb+srv://admin:VotifyAdmin2026@cluster0.1vz2ybc.mongodb.net/votify?retryWrites=true&w=majority
